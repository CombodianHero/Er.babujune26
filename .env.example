# ── Copy this file to .env and fill in your values ───────────────────────────
# Never commit the actual .env file to git!

# Telegram API credentials (get from https://my.telegram.org)
API_ID=0
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (get via @userinfobot)
OWNER=0

# Bot credit/branding name shown in captions
CREDIT=Saini Bots

# Comma-separated list of premium user IDs (owner is always included)
AUTH_USERS=0

# Comma-separated list of all users who started the bot (auto-managed at runtime)
TOTAL_USERS=0

# External DRM key resolver API (optional)
API_URL=
API_TOKEN=

# File paths (defaults are fine)
COOKIES_FILE=youtube_cookies.txt
DOWNLOADS_DIR=downloads

# Web server port (for Render/Railway/Heroku)
PORT=8080
